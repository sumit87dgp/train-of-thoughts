# Train of Thoughts — environment template (safe to commit)
#
# 1. Copy this file to .env (never commit .env):
#      cp .env.example .env
# 2. Replace every placeholder below with your LOCAL-ONLY values.
# 3. DATABASE_URL / DATABASE_URL_API passwords must match TOT_*_PASSWORD.
# 4. For local dev, TOT_API_PASSWORD must match tot_api in migration 003_roles_grants.sql
#    (or run a new migration if you change that role password).

# --- PostgreSQL (Docker Compose) ---
POSTGRES_PORT=5433
TOT_OWNER_PASSWORD=your-local-tot-owner-password
TOT_API_PASSWORD=your-local-tot-api-password

# --- Database connections ---
# tot_owner: migrations (migrate.sh). tot_api: FastAPI runtime.
DATABASE_URL=postgres://tot_owner:your-local-tot-owner-password@localhost:5433/tot?sslmode=disable
DATABASE_URL_API=postgres://tot_api:your-local-tot-api-password@localhost:5433/tot?sslmode=disable

# --- Backend API ---
API_PORT=8000
JWT_SECRET=your-local-jwt-secret-change-me
CORS_ORIGINS=http://localhost:5173

# --- Single-user auth (Phase 2+) ---
TOT_USER=admin
TOT_PASSWORD=your-local-login-password

# --- Frontend ---
VITE_API_URL=http://localhost:8000
